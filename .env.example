# Password for the /admin dashboard.
# For production, generate a bcrypt hash and paste that here instead of plaintext.
# See docs/security.md for how to hash it.
ADMIN_PASSWORD=change-me

# Anthropic API key (https://console.anthropic.com/)
# Used by the AI tailoring, validation, scraping extraction, and AI-assist editing.
ANTHROPIC_API_KEY=sk-ant-...

# Apify API token (https://apify.com/account)
# Used only by the URL-based job-description scraping (LinkedIn + generic sites).
# Optional — leave blank if you only paste JDs manually.
APIFY_API_KEY=apify_api_...

# GitHub fine-grained PAT with Contents: read/write on THIS repo only.
# Used to commit published profiles back to the repo as JSON.
GITHUB_TOKEN=github_pat_...

# Branch the admin writes profile JSONs to. MUST be set to `main` (or whichever
# branch Vercel auto-deploys from). If this points at a feature branch,
# published profiles will never reach production.
GITHUB_BRANCH=main

# NOTE: the GitHub owner + repo are currently hardcoded in lib/github.ts
# (constants OWNER and REPO). When you fork, update those two constants
# to match your GitHub username and repo name.
